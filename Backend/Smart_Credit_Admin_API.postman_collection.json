            "url": {
              "raw": "http://localhost:3000/admin/disputes/dispute-001/resolve",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["admin", "disputes", "dispute-001", "resolve"]
            },
            "description": "Resolve a dispute. Sets status to 'resolved', adds resolution text (required), optional notes, and resolvedAt timestamp. Replace disputeId in path."
          }
        },
