            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resolution\": \"Issue resolved. Full payment disbursed and both parties satisfied.\",\n  \"notes\": \"Dispute closed amicably after mediation\"\n}"
