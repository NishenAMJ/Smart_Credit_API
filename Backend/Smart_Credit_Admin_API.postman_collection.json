              "raw": "http://localhost:3000/admin/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["admin", "users"]
            },
            "description": "Retrieve all users from the system. Returns sanitized user data (excludes passwordHash)."
