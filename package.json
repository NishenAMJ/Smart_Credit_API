{
  "name": "smart-credit-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:web": "npm --workspace apps/web-admin run dev",
    "build:backend": "npm --workspace apps/backend run build",
    "build:web": "npm --workspace apps/web-admin run build",
    "build": "npm run build:backend && npm run build:web"
  }
}

